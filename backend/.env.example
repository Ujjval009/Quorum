# --- Supabase (Auth + API) ---
# Get these from your Supabase project: Settings → API

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Database (Alembic + direct connection) ---
# Get individual connection params from Supabase: Project Settings → Database

DB_HOST=db.your-project-ref.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-password

# --- Eval Suite ---
# Override these if not using the defaults (evaluser@quorum.ai / EvalPass123!)
EVAL_API_URL=http://localhost:8000
EVAL_EMAIL=evaluser@quorum.ai
EVAL_PASSWORD=EvalPass123!

# --- Groq (LLM) ---
# Get your free API key at https://console.groq.com/keys

GROQ_API_KEY=gsk-your-groq-api-key
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# --- Embeddings ---
# Options: ollama (local, free), huggingface
# Ollama: run `ollama pull nomic-embed-text` and `ollama serve`
# HuggingFace: set EMBEDDING_PROVIDER=huggingface + HF_TOKEN
#             Uses sentence-transformers/multi-qa-mpnet-base-dot-v1 (768d)

EMBEDDING_PROVIDER=ollama
EMBEDDING_DIMENSIONS=768
OLLAMA_BASE_URL=http://localhost:11434/v1
HF_TOKEN=

# For production deploy, set EMBEDDING_PROVIDER=huggingface and HF_TOKEN
# Then run: uv run python scripts/ingest_html.py

# --- Ingestion ---

CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Retrieval ---

RETRIEVAL_TOP_K=10
RETRIEVAL_RRF_K=60

# --- Server ---

ALLOWED_ORIGINS=http://localhost:5173
